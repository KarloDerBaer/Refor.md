{
  "name": "refor.md",
  "version": "1.0.1",
  "description": "refor.md - Read, Comment, Refine",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build && electron-builder"
  },
  "keywords": [
    "markdown",
    "editor",
    "electron",
    "reader",
    "desktop"
  ],
  "author": "KarloDerBaer",
  "license": "Apache-2.0",
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/lora": "^5.2.8",
    "dompurify": "^3.0.0",
    "electron-store": "^11.0.2",
    "highlight.js": "^11.11.1",
    "lucide": "^0.575.0",
    "marked": "^12.0.0",
    "tippy.js": "^6.3.7"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^29.0.0",
    "electron-builder": "^26.8.1",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.reformd.app",
    "productName": "refor.md",
    "directories": {
      "output": "release"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh",
      "installerLanguages": [
        "en_US"
      ],
      "language": "1033"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    }
  }
}
